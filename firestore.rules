rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isHR() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'hr';
    }

    function myProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function myCandidateId() {
      return myProfile().candidate_id;
    }

    // profiles: own uid can read/write their profile; HR can read/write any profile
    match /profiles/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read, write: if isHR();
    }

    // candidates: HR full access; candidate can read and update their own
    match /candidates/{candidateId} {
      allow read, write: if isHR();
      allow read, update: if isSignedIn() && myCandidateId() == candidateId;
    }

    // employees: HR full access; employee can read their own record
    match /employees/{employeeId} {
      allow read, write: if isHR();
      allow read: if isSignedIn() && myProfile().employee_id == employeeId;
    }

    // documents: HR full access; candidate can read/write their own docs
    match /documents/{docId} {
      allow read, write: if isHR();
      allow read, write: if isSignedIn() && myCandidateId() == resource.data.candidate_id;
      allow create:      if isSignedIn() && myCandidateId() == request.resource.data.candidate_id;
    }

    // checklist_items: HR full access; candidate can read/write their own items
    match /checklist_items/{itemId} {
      allow read, write: if isHR();
      allow read, write: if isSignedIn() && myCandidateId() == resource.data.candidate_id;
    }

    // alerts: HR only
    match /alerts/{alertId} {
      allow read, write: if isHR();
    }

    // provisioning_requests: HR only
    match /provisioning_requests/{reqId} {
      allow read, write: if isHR();
    }

    // policy sessions and messages: any signed-in user
    match /policy_sessions/{sessionId} {
      allow create: if isSignedIn();
      allow read, write: if isSignedIn() && (
        resource.data.candidate_id == myCandidateId() ||
        resource.data.employee_id  == myProfile().employee_id ||
        isHR()
      );
    }
    match /policy_messages/{msgId} {
      allow read, write: if isSignedIn();
    }
  }
}
